{
  "generatedAt": "2026-05-15",
  "cacheVersion": "v113",
  "storageKey": "lar_assets_v1",
  "description": "Load Asset Registry — full schema reference for LoadStudio asset management.",
  "schema": {
    "assetId":          { "type": "string",  "auto": true,  "example": "asset-1715000000000-4231" },
    "assetType":        { "type": "enum",    "values": ["image","video","audio","subtitle","font","script","cover","other"] },
    "name":             { "type": "string",  "required": true },
    "source":           { "type": "string",  "example": "imported | generated | library | user-imported" },
    "providerId":       { "type": "string",  "nullable": true, "example": "pollinations-image" },
    "pipelineId":       { "type": "string",  "nullable": true, "example": "commercial-image" },
    "sceneId":          { "type": "string",  "nullable": true },
    "characterIds":     { "type": "array",   "items": "string" },
    "wardrobeIds":      { "type": "array",   "items": "string" },
    "propIds":          { "type": "array",   "items": "string" },
    "locationId":       { "type": "string",  "nullable": true },
    "rightsStatus":     { "type": "enum",    "values": ["creator-owned","user-imported","generated","public-domain","licensed","restricted","unknown"] },
    "commercialSafe":   { "type": "boolean", "nullable": true },
    "continuityStatus": { "type": "string",  "nullable": true },
    "productionStatus": { "type": "enum",    "values": ["draft","approved","rejected","needs-upscale","needs-subtitle-timing","continuity-mismatch","pending-render"] },
    "createdAt":        { "type": "string",  "format": "ISO 8601" },
    "blobUrl":          { "type": "string",  "nullable": true, "note": "Session-only. Stripped before localStorage persist." },
    "filePath":         { "type": "string",  "nullable": true },
    "thumbnailUrl":     { "type": "string",  "nullable": true },
    "mimeType":         { "type": "string",  "nullable": true, "example": "image/png" },
    "width":            { "type": "number",  "nullable": true },
    "height":           { "type": "number",  "nullable": true },
    "duration":         { "type": "number",  "nullable": true, "note": "Seconds" },
    "fileSize":         { "type": "number",  "nullable": true, "note": "Bytes" },
    "tags":             { "type": "array",   "items": "string" },
    "notes":            { "type": "string" },
    "group":            { "type": "string",  "auto": true, "note": "Resolved by _resolveGroup(). Never set manually." }
  },
  "groups": {
    "imported":         "Imported",
    "generated-images": "Generated Images",
    "approved-takes":   "Approved Takes",
    "rejected-takes":   "Rejected Takes",
    "upscaled":         "Upscaled",
    "bg-removed":       "Background Removed",
    "audio-stems":      "Audio Stems",
    "subtitles":        "Subtitles",
    "music":            "Music",
    "sfx":              "Sound FX",
    "scripts":          "Scripts",
    "covers":           "Covers",
    "other":            "Other"
  },
  "groupResolutionRules": [
    { "priority": 1, "condition": "assetType === 'subtitle'",                             "group": "subtitles" },
    { "priority": 2, "condition": "assetType === 'script'",                               "group": "scripts" },
    { "priority": 3, "condition": "assetType === 'cover'",                                "group": "covers" },
    { "priority": 4, "condition": "productionStatus === 'rejected'",                      "group": "rejected-takes" },
    { "priority": 5, "condition": "productionStatus === 'approved' && (image or video)",  "group": "approved-takes" },
    { "priority": 6, "condition": "tags includes 'bg-removed'",                           "group": "bg-removed" },
    { "priority": 7, "condition": "tags includes 'upscaled' || status === 'needs-upscale'", "group": "upscaled" },
    { "priority": 8, "condition": "audio && tags includes 'stem'",                        "group": "audio-stems" },
    { "priority": 9, "condition": "audio && tags includes 'sfx'",                         "group": "sfx" },
    { "priority": 10, "condition": "audio && (tags includes 'music' || source === 'library')", "group": "music" },
    { "priority": 11, "condition": "image && source === 'generated'",                     "group": "generated-images" },
    { "priority": 12, "condition": "source === 'imported' || source === 'user-imported'", "group": "imported" },
    { "priority": 13, "condition": "(fallback)",                                          "group": "other" }
  ],
  "securityNotes": [
    "blobUrl is stripped before localStorage persist — blob URLs are session-only.",
    "addAsset() and updateAsset() scrub apiKey, token, and secret before storing.",
    "exportManifest() strips blobUrl and never includes keys.",
    "registerProviderResult() never passes API keys through result objects."
  ],
  "publicAPI": [
    "addAsset(fields)",
    "updateAsset(assetId, updates)",
    "removeAsset(assetId)",
    "getAsset(assetId)",
    "listAssets()",
    "listByType(assetType)",
    "listByGroup(group)",
    "listByPipeline(pipelineId)",
    "listByStatus(productionStatus)",
    "listByScene(sceneId)",
    "listCommercialSafe()",
    "searchAssets(query)",
    "groupedAssets()",
    "summary()",
    "exportManifest()",
    "registerProviderResult(result, overrides)"
  ]
}
